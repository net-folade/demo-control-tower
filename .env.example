# Python pipeline environment variables
# Copy this file to .env and fill in real values. Never commit .env.

# Supabase — get from https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# OpenWeather — free signup at https://openweathermap.org/api
OPENWEATHER_KEY=your-openweather-api-key

# UN Comtrade — optional free key from https://comtradeplus.un.org/
COMTRADE_KEY=your-comtrade-subscription-key
